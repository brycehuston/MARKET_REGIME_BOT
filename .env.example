# MARKET REGIME BOT V1
# Alert-only. No wallet. No private keys. No execution.

# Optional but recommended for Telegram alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional. Public CoinGecko can work without a key, but a demo key improves reliability.
# For normal public API base URL, use x-cg-demo-api-key.
COINGECKO_DEMO_API_KEY=

# If true, sends one startup snapshot per bot process start.
# In loop mode this does NOT spam every 15 minutes.
SEND_STARTUP_ALERT=false

# Optional low-spam Telegram heartbeat. Sends only when Telegram is configured.
TELEGRAM_HEARTBEAT_ENABLED=false
TELEGRAM_HEARTBEAT_INTERVAL_MINUTES=60
# Display-only lane explainer guidance. Default enabled; set false to use simpler alert rows.
ALPHA_PULSE_EXPLAINER_MODE=true
# Market candle provider. Use coingecko on hosts where exchange APIs are geo-blocked.
MARKET_DATA_PRIMARY=coingecko
BYBIT_BASE_URL=https://api.bybit.com
# Optional DeFi/on-chain confirmation from DefiLlama free API. No key required.
DEFILLAMA_CONFIRMATION_ENABLED=true
DEFILLAMA_BASE_URL=https://api.llama.fi
DEFILLAMA_TIMEOUT_MS=10000
# Optional derivatives/leverage heat confirmation from Coinalyze.
# Report-only. No execution. API key is sent via header only.
DERIVATIVES_HEAT_ENABLED=false
DERIVATIVES_HEAT_PROVIDER=coinalyze
COINALYZE_API_KEY=
COINALYZE_BASE_URL=https://api.coinalyze.net/v1
DERIVATIVES_HEAT_TIMEOUT_MS=10000
DERIVATIVES_HEAT_ASSETS=BTC,ETH,SOL
DERIVATIVES_HEAT_INTERVAL=1hour
DERIVATIVES_HEAT_HISTORY_HOURS=168
